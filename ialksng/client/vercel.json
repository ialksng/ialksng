{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ialksng-backend.onrender.com/api/:path*"
    },
    {
      "source": "/chatflow-api/:path*",
      "destination": "https://chatflow-zvul.onrender.com/api/:path*"
    },

    {
      "source": "/projects/chatflow",
      "destination": "https://chatflow-zvul.onrender.com/"
    },
    {
      "source": "/projects/chatflow/:path*",
      "destination": "https://chatflow-zvul.onrender.com/:path*"
    },

    {
      "source": "/projects/smartsphere",
      "destination": "https://smartsphere-2n32.onrender.com/"
    },
    {
      "source": "/projects/smartsphere/:path*",
      "destination": "https://smartsphere-2n32.onrender.com/:path*"
    },

    {
      "source": "/projects/truthlens",
      "destination": "https://truthlens-3r4q.onrender.com/"
    },
    {
      "source": "/projects/truthlens/:path*",
      "destination": "https://truthlens-3r4q.onrender.com/:path*"
    },

    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}