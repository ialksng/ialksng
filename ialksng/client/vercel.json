{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ialksng-backend.onrender.com/api/$1"
    },
    {
      "source": "/chatflow-api/(.*)",
      "destination": "https://chatflow-zvul.onrender.com/api/$1"
    },

    {
      "source": "/projects/chatflow",
      "destination": "https://chatflow-zvul.onrender.com/"
    },
    {
      "source": "/projects/chatflow/(.*)",
      "destination": "https://chatflow-zvul.onrender.com/$1"
    },

    {
      "source": "/projects/smartsphere",
      "destination": "https://smartsphere-2n32.onrender.com/projects/smartsphere"
    },
    {
      "source": "/projects/smartsphere/(.*)",
      "destination": "https://smartsphere-2n32.onrender.com/projects/smartsphere/$1"
    },

    {
      "source": "/projects/truthlens",
      "destination": "https://truthlens.onrender.com/"
    },
    {
      "source": "/projects/truthlens/(.*)",
      "destination": "https://truthlens.onrender.com/$1"
    },

    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}